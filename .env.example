# ── LLM ─────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=google/gemini-flash-1.5
QUALITY_MODEL=anthropic/claude-3.5-sonnet

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://raguser:ragpass@localhost:5432/ragdb

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rag-documents
MINIO_SECURE=false

# ── Langfuse ──────────────────────────────────────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=http://localhost:3000

# ── Auth ──────────────────────────────────────────────────────────────────────
API_SECRET_SALT=changeme-use-a-random-string

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Guardrails ────────────────────────────────────────────────────────────────
GUARDRAILS_PII_ENABLED=true
GUARDRAILS_HALLUCINATION_THRESHOLD=0.75
GUARDRAILS_TOXICITY_ENABLED=true

# ── Cache sémantique ──────────────────────────────────────────────────────────
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92
SEMANTIC_CACHE_TTL_SECONDS=3600

# ── RAG ───────────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development   # development | production
LOG_LEVEL=INFO
